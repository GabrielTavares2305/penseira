import { useState } from 'react'
import { ExternalLink, Search, MapPin } from 'lucide-react'

// Estados brasileiros
const ESTADOS = [
  { uf:'', nome:'Todo o Brasil' },
  { uf:'RJ', nome:'Rio de Janeiro' },
  { uf:'SP', nome:'São Paulo' },
  { uf:'MG', nome:'Minas Gerais' },
  { uf:'RS', nome:'Rio Grande do Sul' },
  { uf:'PR', nome:'Paraná' },
  { uf:'SC', nome:'Santa Catarina' },
  { uf:'BA', nome:'Bahia' },
  { uf:'PE', nome:'Pernambuco' },
  { uf:'CE', nome:'Ceará' },
  { uf:'GO', nome:'Goiás' },
  { uf:'DF', nome:'Distrito Federal' },
  { uf:'AM', nome:'Amazonas' },
  { uf:'PA', nome:'Pará' },
  { uf:'REMOTO', nome:'Remoto / Home Office' },
]

// Tecnologias populares para filtro rápido
const TECHS = ['', 'React', 'Python', 'Java', 'Node.js', 'SQL', 'Linux', 'Docker', 'AWS', 'C#', 'PHP', 'Flutter']

// Função que monta URLs reais dos portais com os filtros escolhidos
function buildLinks(tipo, estado, tech, termo) {
  const q = [termo, tech].filter(Boolean).join(' ')
  const tipoLabel = tipo === 'estagio' ? 'estágio' : 'junior'
  const busca = [tipoLabel, 'tecnologia', q].filter(Boolean).join(' ')
  const estadoNome = ESTADOS.find(e => e.uf === estado)?.nome || ''
  const locGupy = estado === 'REMOTO' ? 'home-office' : estadoNome
  const locLinkedin = estado === 'REMOTO' ? 'remote' : estadoNome
  const locIndeed = estado === 'REMOTO' ? 'home+office' : estadoNome.replace(/ /g, '+')

  return [
    {
      portal: 'Gupy',
      desc: 'Maior portal de vagas do Brasil — empresas como iFood, Nubank, Totvs',
      cor: '#00D4AA',
      url: `https://portal.gupy.io/job-search/term=${encodeURIComponent(busca)}${locGupy ? `&jobTypes=${tipo === 'estagio' ? 'internship' : 'effective'}&state=${encodeURIComponent(locGupy)}` : ''}`,
    },
    {
      portal: 'LinkedIn Jobs',
      desc: 'Rede profissional com milhares de vagas atualizadas diariamente',
      cor: '#0A66C2',
      url: `https://www.linkedin.com/jobs/search/?keywords=${encodeURIComponent(busca)}&location=${encodeURIComponent(locLinkedin || 'Brasil')}&f_WT=${estado === 'REMOTO' ? '2' : ''}`,
    },
    {
      portal: 'Indeed',
      desc: 'Agregador com vagas de centenas de empresas e sites',
      cor: '#2164F3',
      url: `https://br.indeed.com/jobs?q=${encodeURIComponent(busca)}&l=${locIndeed || 'Brasil'}`,
    },
    {
      portal: 'CIEE',
      desc: 'Especializado em estágio — muito usado por universidades',
      cor: '#E87722',
      url: `https://portal.ciee.org.br/estagio/?q=${encodeURIComponent(q || 'tecnologia')}${estadoNome ? `&estado=${encodeURIComponent(estadoNome)}` : ''}`,
      hidden: tipo !== 'estagio',
    },
    {
      portal: 'Catho',
      desc: 'Uma das maiores plataformas de emprego do Brasil',
      cor: '#C9A84C',
      url: `https://www.catho.com.br/vagas/${encodeURIComponent(busca.replace(/ /g,'-'))}/${estado && estado !== 'REMOTO' ? encodeURIComponent(estadoNome.toLowerCase().replace(/ /g,'-')) : ''}`,
    },
    {
      portal: 'Vagas.com.br',
      desc: 'Portal focado no mercado brasileiro com bom filtro regional',
      cor: '#9B7FC0',
      url: `https://www.vagas.com.br/vagas-de-${encodeURIComponent(tipoLabel)}-em-${encodeURIComponent((q || 'ti').replace(/ /g,'-'))}${estadoNome ? `-em-${encodeURIComponent(estadoNome.toLowerCase().replace(/ /g,'-'))}` : ''}`,
    },
  ].filter(l => !l.hidden)
}

function CardCorners() {
  return (<><div className="card-corner tl"/><div className="card-corner br"/></>)
}

export default function Jobs() {
  const [tipo,   setTipo]   = useState('estagio')
  const [estado, setEstado] = useState('')
  const [tech,   setTech]   = useState('')
  const [termo,  setTermo]  = useState('')

  const links = buildLinks(tipo, estado, tech, termo)

  return (
    <div>
      {/* Filtros */}
      <div className="card" style={{ marginBottom: 20 }}>
        <CardCorners />
        <div className="card-label">// CONFIGURAR BUSCA <span className="card-label-right">OS LINKS JÁ ABREM FILTRADOS</span></div>

        {/* Tipo */}
        <div className="form-group">
          <label className="form-label">TIPO DE VAGA</label>
          <div style={{ display: 'flex', gap: 8 }}>
            {[['estagio','🎓 ESTÁGIO'], ['junior','💼 JÚNIOR / TRAINEE']].map(([v, l]) => (
              <button key={v} className={`btn ${tipo === v ? 'btn-gold' : 'btn-outline'}`} style={{ fontSize: 11 }} onClick={() => setTipo(v)}>{l}</button>
            ))}
          </div>
        </div>

        {/* Estado */}
        <div className="form-group">
          <label className="form-label"><MapPin size={10} style={{ display:'inline', marginRight:4 }} />ESTADO</label>
          <div style={{ display: 'flex', gap: 6, flexWrap: 'wrap' }}>
            {ESTADOS.map(e => (
              <button key={e.uf} className={`btn ${estado === e.uf ? 'btn-gold' : 'btn-outline'}`}
                style={{ fontSize: 10, padding: '5px 10px' }} onClick={() => setEstado(e.uf)}>
                {e.uf || '🇧🇷'} {e.uf ? e.uf : 'TODOS'}
              </button>
            ))}
          </div>
        </div>

        {/* Tecnologia */}
        <div className="form-group">
          <label className="form-label">TECNOLOGIA / ÁREA</label>
          <div style={{ display: 'flex', gap: 6, flexWrap: 'wrap' }}>
            {TECHS.map(t => (
              <button key={t} className={`btn ${tech === t ? 'btn-gold' : 'btn-outline'}`}
                style={{ fontSize: 10, padding: '5px 10px' }} onClick={() => setTech(t)}>
                {t || 'QUALQUER'}
              </button>
            ))}
          </div>
        </div>

        {/* Termo livre */}
        <div className="form-group" style={{ marginBottom: 0 }}>
          <label className="form-label">TERMO ADICIONAL (OPCIONAL)</label>
          <div style={{ position: 'relative' }}>
            <Search size={13} style={{ position:'absolute', left:10, top:'50%', transform:'translateY(-50%)', color:'var(--text-muted)' }} />
            <input className="input" style={{ paddingLeft: 32 }}
              placeholder="EX: SUPORTE, DADOS, SEGURANÇA..."
              value={termo} onChange={e => setTermo(e.target.value)} />
          </div>
        </div>
      </div>

      {/* Resumo do filtro ativo */}
      <div style={{ fontFamily: 'var(--font-hud)', fontSize: 10, color: 'var(--cyan-dim)', letterSpacing: 2, marginBottom: 16 }}>
        // BUSCANDO: <span style={{ color: 'var(--gold)' }}>
          {tipo === 'estagio' ? 'ESTÁGIO' : 'JÚNIOR'} EM TI
          {tech ? ` · ${tech.toUpperCase()}` : ''}
          {termo ? ` · ${termo.toUpperCase()}` : ''}
          {estado ? ` · ${ESTADOS.find(e => e.uf === estado)?.nome.toUpperCase()}` : ' · TODO O BRASIL'}
        </span>
      </div>

      {/* Cards dos portais */}
      <div className="grid-2">
        {links.map(l => (
          <div key={l.portal} className="card" style={{ borderLeft: `2px solid ${l.cor}` }}>
            <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'flex-start', marginBottom: 10 }}>
              <div>
                <div style={{ fontFamily: 'var(--font-title)', fontSize: 16, color: 'var(--cream)', marginBottom: 4 }}>{l.portal}</div>
                <div style={{ fontFamily: 'var(--font-hud)', fontSize: 11, color: 'var(--text-secondary)', lineHeight: 1.5 }}>{l.desc}</div>
              </div>
              <div style={{ width: 10, height: 10, borderRadius: '50%', background: l.cor, flexShrink: 0, marginTop: 4, boxShadow: `0 0 8px ${l.cor}` }} />
            </div>
            <a href={l.url} target="_blank" rel="noopener" className="btn btn-gold" style={{ fontSize: 11, width: '100%', justifyContent: 'center' }}>
              <ExternalLink size={11} /> ABRIR COM FILTROS APLICADOS
            </a>
          </div>
        ))}
      </div>

      {/* Dica */}
      <div className="card" style={{ marginTop: 20, borderColor: 'rgba(0,255,200,0.15)' }}>
        <div className="card-label">// DICA DE USO</div>
        <div style={{ fontFamily: 'var(--font-hud)', fontSize: 11, color: 'var(--text-secondary)', lineHeight: 2, letterSpacing: 0.5 }}>
          <div>① Configure o tipo, estado e tecnologia acima</div>
          <div>② Clique no portal de sua preferência — ele já abre com os filtros aplicados</div>
          <div>③ No portal, você pode refinar ainda mais por data de publicação, salário e regime</div>
          <div style={{ marginTop: 8, color: 'var(--cyan-dim)' }}>
            💡 Para vagas mais recentes, no LinkedIn use o filtro <span style={{ color: 'var(--gold)' }}>"Últimas 24 horas"</span> após abrir
          </div>
        </div>
      </div>
    </div>
  )
}
